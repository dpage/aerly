# Example nginx config for Aerly behind a Let's Encrypt cert.
# Place under /etc/nginx/sites-available/ and symlink into sites-enabled.
#
# Notes:
#   - The Go process serves the SPA, JSON API, OAuth callback, and SSE stream
#     on a single upstream — nginx only does TLS termination and forwarding.
#   - proxy_buffering must be off for /api/events so Server-Sent Events flush
#     to the client immediately.
#   - Security headers (Content-Security-Policy, X-Frame-Options,
#     X-Content-Type-Options, Referrer-Policy, and HSTS for HTTPS deployments)
#     are emitted by the Go application itself, so there is no add_header block
#     here. Don't re-add Content-Security-Policy at the nginx layer: a second
#     CSP header is combined with the app's by the browser (intersection of the
#     two policies), which silently tightens it and tends to break the map and
#     avatars. If you must set headers at the edge, do it instead of the app's,
#     not in addition.

server {
    listen 443 ssl http2;
    server_name aerly.me;

    ssl_certificate     /etc/letsencrypt/live/aerly.me/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/aerly.me/privkey.pem;

    # Standard reverse-proxy block.
    location / {
        proxy_pass         http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # Server-Sent Events: keep the connection alive and unbuffered.
    location /api/events {
        proxy_pass         http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_buffering    off;
        proxy_cache        off;
        proxy_read_timeout 1h;
        chunked_transfer_encoding on;
    }
}

server {
    listen 80;
    server_name aerly.me;
    return 301 https://$host$request_uri;
}
