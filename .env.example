# Copy to .env (gitignored) and fill in real values for local dev.

LISTEN_ADDR=:8080
PUBLIC_URL=http://localhost:8080

DATABASE_URL=postgres://flight_tracker:flight_tracker@localhost:5432/flight_tracker?sslmode=disable

# GitHub OAuth app: https://github.com/settings/developers
# Authorization callback URL = ${PUBLIC_URL}/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 32+ random bytes, base64 or hex. Used to sign session cookies.
# Generate: openssl rand -base64 48
SESSION_KEY=

# OpenSky Network position tracker.
#
# If OPENSKY_USERNAME is set, the poller queries OpenSky for live ADS-B
# positions using HTTP Basic Auth. Without credentials, set OPENSKY_ENABLED=1
# to use OpenSky anonymously (heavily rate-limited — fine for one or two
# flights). Leave both blank to fall back to the in-memory stub backend.
#
# Either way the tracker is wrapped in a dead-reckoner that extrapolates
# along the great-circle from the last real fix toward the destination,
# parameterised by remaining scheduled time, when OpenSky goes quiet
# (e.g. oceanic gaps). Estimated positions are flagged so the UI renders
# them with reduced opacity and a dashed outline.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
OPENSKY_ENABLED=0

# AeroDataBox schedule resolver (via RapidAPI).
#
# When set, POST /api/flights/resolve looks up the full schedule + airports
# + airframe icao24 for a flight number + departure date, and the frontend
# switches the Add Flight dialog to its minimal "ident + date" form. Leave
# blank to keep the manual-entry dialog and disable /api/flights/resolve.
# Sign up at https://rapidapi.com/aedbx-aedbx/api/aerodatabox/ — a few
# dollars a month covers thousands of resolves.
AERODATABOX_RAPIDAPI_KEY=

# How often the poller refreshes active flights. Anything accepted by
# time.ParseDuration: 30s, 1m, 5m, etc. Non-Enroute flights are throttled
# to 5× this interval automatically.
POLL_INTERVAL=60s

# Local development only: bypass GitHub OAuth and allow
#   GET /auth/dev-login?login=<github-handle>
# to mint a session for any handle. Refuses to start if PUBLIC_URL is non-localhost.
# DO NOT enable in production.
DEV_AUTH_BYPASS=0
